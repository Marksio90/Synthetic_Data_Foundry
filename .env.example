# =============================================================================
# ESG Data Foundry — Environment variables template
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── vLLM / Hugging Face ──────────────────────────────────────────────────────
# Token with read access to meta-llama/Llama-3.1-8B-Instruct
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXX
# Model served by vLLM (must be AWQ-quantized variant for memory efficiency)
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=o1-mini

# ── LlamaParse (optional) ─────────────────────────────────────────────────────
# Leave empty to use OpenAI Vision API fallback
LLAMA_PARSE_API_KEY=

# ── Pipeline tuning ──────────────────────────────────────────────────────────
ADVERSARIAL_RATIO=0.10        # fraction of adversarial questions (0.0–1.0)
QUALITY_THRESHOLD=0.90        # minimum judge score to accept a sample
MAX_RETRIES_PER_CHUNK=3       # Self-Check: max judge rejections before unresolvable
WATERMARK_INTERVAL=50         # inject linguistic watermark every N records
BATCH_SIZE=10

# ── Output ───────────────────────────────────────────────────────────────────
OUTPUT_FILE=/app/output/dataset_esg_v1.jsonl
CLIENT_ID=client_acme_2024     # unique per customer for B2B watermark tracking

# ── Tenacity / Self-Check 2.0 ────────────────────────────────────────────────
TENACITY_MAX_ATTEMPTS=6
TENACITY_INITIAL_WAIT=2.0     # seconds (doubles each retry: 2→4→8→16→32→64)
TENACITY_MAX_WAIT=64.0

# ── B2B Watermark secret (Self-Check) ────────────────────────────────────────
# Change to a long random string — used in watermark hash derivation
FOUNDRY_WATERMARK_SECRET=change-me-to-a-random-256-bit-secret

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
