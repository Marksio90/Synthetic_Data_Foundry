# =============================================================================
# ESG Data Foundry — zmienne środowiskowe
# Skopiuj do .env i wypełnij. Nigdy nie commituj .env do gita.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=CHANGE_ME

DATABASE_URL=postgresql+psycopg2://esg_user:CHANGE_ME@localhost:5432/esg_foundry
ASYNC_DATABASE_URL=postgresql+asyncpg://esg_user:CHANGE_ME@localhost:5432/esg_foundry

# =============================================================================
# WARIANT A — ZALECANY: OpenAI gpt-4o-mini (bez limitów dobowych, ~$2/1000 próbek)
# =============================================================================
OPENAI_API_KEY=sk-XXXX          # wymagany zawsze (judge + embeddingi)
GROQ_API_KEY=                   # PUSTE = używa OpenAI dla generacji
VLLM_BASE_URL=https://api.openai.com/v1
VLLM_MODEL=gpt-4o-mini
VLLM_API_KEY=                   # puste = używa OPENAI_API_KEY

# =============================================================================
# WARIANT B — NAJTAŃSZY: Gemini 2.0 Flash Lite (~$0.60/1000 próbek)
# Wymaga klucza Google AI: https://aistudio.google.com/apikey
# =============================================================================
# OPENAI_API_KEY=sk-XXXX        # nadal wymagany dla judge + embeddings
# GROQ_API_KEY=                 # puste
# VLLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# VLLM_MODEL=gemini-2.0-flash-lite
# VLLM_API_KEY=AIza-XXXX        # Google AI API key

# =============================================================================
# WARIANT C — NAJSZYBSZY: Groq paid (llama-3.1-8b-instant, $0.30/1000 próbek)
# Wymaga płatnego Groq Dev Tier: https://console.groq.com/settings/billing
# =============================================================================
# GROQ_API_KEY=gsk_XXXX
# GROQ_MODEL=llama-3.1-8b-instant

# ── OpenAI (judge + embeddings — zawsze wymagany) ─────────────────────────────
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ── PDF Parsing ───────────────────────────────────────────────────────────────
# Domyślnie: PyMuPDF lokalnie (darmowy, bez limitu)
# Opcjonalnie LlamaParse dla złożonych tabel ($0.003/str):
# LLAMA_PARSE_API_KEY=llx-XXXX

# ── Pipeline ─────────────────────────────────────────────────────────────────
ADVERSARIAL_RATIO=0.10
QUALITY_THRESHOLD=0.75
MAX_RETRIES_PER_CHUNK=3
MAX_TURNS=3
MAX_REFUSAL_RATIO=0.10
CHUNK_DELAY_SECONDS=1.0
WATERMARK_INTERVAL=50
BATCH_SIZE=10

# ── HuggingFace (trening lokalny — opcjonalny) ───────────────────────────────
HF_TOKEN=hf_XXXX

# ── Ollama (chatbot — opcjonalny) ────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
