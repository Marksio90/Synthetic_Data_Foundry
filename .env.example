# =============================================================================
# ESG Data Foundry — Environment variables template
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Groq (Llama 3.3 70B — PRIMARY question/answer generator) ─────────────────
# Get free API key at: https://console.groq.com
# Leave empty to fall back to OpenAI for question generation
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXX
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── OpenAI (Judge + Embeddings — always required) ────────────────────────────
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXX
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o

# ── LlamaParse (PDF parser — recommended) ────────────────────────────────────
# Get key at: https://cloud.llamaindex.ai — $0.003/page vs $0.03 for Vision
# Leave empty to use OpenAI Vision API as fallback
LLAMA_PARSE_API_KEY=llx-XXXXXXXXXXXXXXXXXXXX

# ── vLLM / Hugging Face (only if running local GPU with sm70+ — optional) ────
# Leave as-is if using Groq + OpenAI (no local GPU needed)
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXX
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ── Pipeline tuning ──────────────────────────────────────────────────────────
ADVERSARIAL_RATIO=0.10        # fraction of adversarial questions (0.0–1.0)
QUALITY_THRESHOLD=0.75        # minimum judge score to accept a sample
MAX_RETRIES_PER_CHUNK=3       # max judge rejections before chunk is skipped
MAX_TURNS=3                   # conversation turns per chunk (1=single Q&A, 3=recommended)
MAX_REFUSAL_RATIO=0.10        # max fraction of "Brak danych" records in output
WATERMARK_INTERVAL=50         # inject linguistic watermark every N records
BATCH_SIZE=10

# ── AutoPilot / Studio ───────────────────────────────────────────────────────
# Optional: DeepL for high-quality legal translation (falls back to Groq if empty)
DEEPL_API_KEY=
# Source language of documents ('auto'=detect, 'pl', 'en', 'de', 'fr')
SOURCE_LANGUAGE=auto
# Calibration: number of chunks to sample for auto-threshold tuning
CALIBRATION_SAMPLES=50

# ── Chatbot Studio / Ollama ──────────────────────────────────────────────────
# URL Ollamy — w Docker Compose używaj nazwy serwisu (nie localhost!)
# Uruchomienie stosu chatbota: docker compose --profile chatbot up -d
OLLAMA_URL=http://ollama:11434

# ── PRO features ─────────────────────────────────────────────────────────────
DEDUP_THRESHOLD=0.85          # MinHash Jaccard threshold for near-duplicate removal (0.0–1.0)
CROSS_DOC_SAMPLES=50          # cross-document synthesis Q&A pairs per run (0 = disabled)
DPO_OUTPUT_FILE=/app/output/dataset_esg_v1_dpo.jsonl   # DPO preference pairs output
VLLM_MAX_TOKENS=1536          # max tokens for Groq/vLLM generation (increase for longer CoT)

# ── Batch / Output ───────────────────────────────────────────────────────────
BATCH_ID=esg-production-v1    # logical run identifier
OUTPUT_FILE=/app/output/dataset_esg_v1.jsonl
CLIENT_ID=client_acme_2024    # unique per customer for B2B watermark tracking

# ── Tenacity backoff (OpenAI/Groq rate-limit retry) ─────────────────────────
TENACITY_MAX_ATTEMPTS=6
TENACITY_INITIAL_WAIT=2.0     # seconds (doubles each retry: 2→4→8→16→32→64)
TENACITY_MAX_WAIT=64.0

# ── B2B Watermark secret ─────────────────────────────────────────────────────
# Change to a long random string — used in watermark hash derivation
FOUNDRY_WATERMARK_SECRET=change-me-to-a-random-256-bit-secret

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
