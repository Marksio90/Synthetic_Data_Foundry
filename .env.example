# =============================================================================
# ESG Data Foundry — Gods Finger v2 — zmienne środowiskowe
# Skopiuj do .env i wypełnij. NIGDY nie commituj .env do gita.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+psycopg2://esg_user:CHANGE_ME@localhost:5432/esg_foundry
ASYNC_DATABASE_URL=postgresql+asyncpg://esg_user:CHANGE_ME@localhost:5432/esg_foundry

# ── OpenAI — Judge + Embeddings ───────────────────────────────────────────────
OPENAI_API_KEY=sk-XXXX
OPENAI_PRIMARY_MODEL=gpt-4o-mini   # judge (~$0.15/1M tok) — ZOSTAW
OPENAI_FALLBACK_MODEL=gpt-4o       # eskalacja ~5% przypadków ($2.5/1M tok)

# ── LOCAL MODEL (Ollama) — PODSTAWOWY, DARMOWY ────────────────────────────────
# Generacja Q&A przez model lokalny. Wymagania: ~9 GB RAM (qwen2.5:14b).
# 32 GB RAM = wystarczy z DUŻĄ rezerwą.
#
# Modele pobierane AUTOMATYCZNIE przez Docker przy starcie (docker compose up).
# Jeśli model już istnieje → NIE pobiera ponownie (idempotentne).
# Ręczna zmiana modelu: zmień OLLAMA_MODEL poniżej i zrestartuj docker compose.
#
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text
USE_LOCAL_EMBEDDINGS=false          # zmień na true aby używać lokalnych embeddingów (Ollama)
OLLAMA_URL=http://ollama:11434      # adres Ollama w Docker (nie zmieniaj)

# ── PDF Parsing ───────────────────────────────────────────────────────────────
# LlamaParse: najlepsza jakość dla PDF z tabelami ($0.003/str)
LLAMA_PARSE_API_KEY=llx-XXXX

# ── Audio Transcription — Replicate Whisper large-v3 ─────────────────────────
# Transkrypcja nagrań konferencji ESG, webinarów, wywiadów → dane treningowe
# Koszt: ~$0.0002/min. Klucz: https://replicate.com
REPLICATE_API_KEY=r8_XXXX

# ── HuggingFace Hub — auto-upload datasetu i modelu ──────────────────────────
# Po zakończeniu pipeline'u dataset jest automatycznie uploadowany do HF Hub.
# Klucz: https://huggingface.co/settings/tokens (Write access)
HF_TOKEN=hf_XXXX
HF_DATASET_REPO=your-org/esg-foundry-dataset   # np. marksio90/esg-regulatory-qa
HF_MODEL_REPO=your-org/esg-foundry-model       # np. marksio90/esg-llm-v1

# ── Tłumaczenie na POLSKI ─────────────────────────────────────────────────────
# Cel jest zawsze PL (hardcoded). Fallback = OpenAI gpt-4o-mini (zawsze dostępny).
#
# Przepływ:
#   PDF/źródło obcojęzyczne
#     → chunki → translator.py → język POLSKI
#       → generowanie Q&A → dataset
#
# TRANSLATE_CHUNKS=true  → aktywuje tłumaczenie w głównym pipeline'ie
# TRANSLATE_SOURCE_LANG  → język źródłowy chunków z PDF (np. "en", "de", "fr")
#                          Scout używa języka z metadanych źródła (auto)
#
# Obsługiwane języki (DeepL): en, de, fr, es, it, pt, nl, pl,
#                              ja, zh, ko, ru, ar  ← języki Gap Scout
# Brak klucza DeepL → OpenAI fallback (droższy, ale działa)
#
DEEPL_API_KEY=                      # DeepL API key (opcjonalny — klucz Free: https://www.deepl.com/pro#developer)
TRANSLATE_CHUNKS=false              # true = tłumacz chunki z PDF przed Q&A
TRANSLATE_SOURCE_LANG=en            # język źródłowy PDFów (tylko gdy TRANSLATE_CHUNKS=true)

# ── Constitutional AI ─────────────────────────────────────────────────────────
# self-critique + revision: każda odpowiedź przechodzi przez audyt Konstytucji AI.
# Oryginalna (gorsza) odpowiedź automatycznie staje się "rejected" w parze DPO/ORPO/KTO.
# DARMOWE — używa tego samego modelu co generacja (Ollama qwen2.5:14b).
USE_CONSTITUTIONAL_AI=true

# ── 8 perspektyw eksperckich ──────────────────────────────────────────────────
# Każdy chunk × każda perspektywa = osobny rekord treningowy.
# Usuń perspektywy których nie chcesz (mniej = szybciej).
PERSPECTIVES=["cfo","prawnik","audytor","analityk","regulator","akademik","dziennikarz","inwestor"]

# ── Pipeline ──────────────────────────────────────────────────────────────────
ADVERSARIAL_RATIO=0.10             # 10% pytań-pułapek (halucynacja test)
QUALITY_THRESHOLD=0.75             # min. score judge do akceptacji
MAX_RETRIES_PER_CHUNK=3
MAX_TURNS=3                        # tury konwersacji per chunk
MAX_REFUSAL_RATIO=0.10             # max. % odmów "Brak danych" w datasecie
WATERMARK_INTERVAL=50              # co N rekordów → B2B watermark
CHUNK_DELAY_SECONDS=0              # opóźnienie między chunkami (0 = brak)

# ── Batch / Output ────────────────────────────────────────────────────────────
BATCH_ID=esg-production-v1
OUTPUT_FILE=/app/output/dataset_esg_v1.jsonl
DPO_OUTPUT_FILE=/app/output/dataset_esg_v1_dpo.jsonl
ORPO_OUTPUT_FILE=/app/output/dataset_esg_v1_orpo.jsonl   # ← NOWE
KTO_OUTPUT_FILE=/app/output/dataset_esg_v1_kto.jsonl     # ← NOWE
CLIENT_ID=client_acme_2024

# ── PRO features ──────────────────────────────────────────────────────────────
DEDUP_THRESHOLD=0.85
CROSS_DOC_SAMPLES=50
GENERATION_MAX_TOKENS=2048
HYBRID_VECTOR_WEIGHT=0.50
HYBRID_BM25_WEIGHT=0.50
ADAPTIVE_HYBRID_WEIGHTS=true
ADAPTIVE_WEIGHT_SCOPE_BONUS=0.10
ADAPTIVE_WEIGHT_COMPARATIVE_BONUS=0.10

# ── Tenacity — backoff przy błędach API ───────────────────────────────────────
TENACITY_MAX_ATTEMPTS=6
TENACITY_INITIAL_WAIT=2.0
TENACITY_MAX_WAIT=64.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Gap Scout — rozszerzone źródła (KROK 6-12) ───────────────────────────────

# Allowlist crawlerów (puste = wszystkie 46 aktywne)
# Przykład: SCOUT_SOURCES_ENABLED=["arxiv","eurlex","hackernews","openalex"]
SCOUT_SOURCES_ENABLED=[]

# Filtr wyników Gap Scout
SCOUT_MIN_GAP_SCORE=0.35               # Minimalny próg KNOWLEDGE_GAP_SCORE (0.0–1.0)

# Modele LLM do analizy luk (daty odcięcia danych treningowych)
SCOUT_MODEL_TARGETS=["gpt-4o","claude-3.5-sonnet","llama-3","gemini-1.5","mistral"]
SCOUT_CUTOFF_GPT4O=2024-04-01
SCOUT_CUTOFF_CLAUDE35=2024-04-01
SCOUT_CUTOFF_LLAMA3=2024-03-01
SCOUT_CUTOFF_GEMINI15=2024-02-01

# Języki skanowania (BCP-47)
SCOUT_LANGUAGES=["en","de","fr","ja","zh","ko","ar","ru","pt","es"]

# Wydajność
SCOUT_MAX_CONCURRENT_CRAWLERS=20       # Maks. równoległych crawlerów (1–100)
SCOUT_VERIFICATION_MAX_CONCURRENT=8    # Maks. równoległych połączeń HTTP podczas weryfikacji

# Warstwa A
IEEE_API_KEY=                          # IEEE Xplore (darmowe — developer.ieee.org)
CORE_API_KEY=                          # CORE.ac.uk (darmowe — core.ac.uk/services/api)

# Warstwa D
PRODUCTHUNT_API_KEY=                   # Product Hunt OAuth2 Bearer (opcjonalne)

# Warstwa E
YOUTUBE_API_KEY=                       # YouTube Data API v3 (darmowe, 10k jednostek/dzień)
PODCAST_INDEX_API_KEY=                 # Podcast Index (darmowe — podcastindex.org)
PODCAST_INDEX_API_SECRET=              # Paired z PODCAST_INDEX_API_KEY
EUROPEANA_API_KEY=                     # Europeana API (darmowe — pro.europeana.eu)
                                       # Pusty = używa klucza demonstracyjnego 'api2demo'

# Scoring — SerpAPI do pomiaru niche_penetration (opcjonalne)
SCOUT_SERPAPI_KEY=                     # SerpAPI key (serpapi.com)

# Tłumaczenie treści przez Scout (niezależne od globalnego DEEPL_API_KEY)
SCOUT_DEEPL_API_KEY=                   # Nadpisuje DEEPL_API_KEY dla zapytań Scout

# WebSub Tier 1 — real-time push (opcjonalne)
SCOUT_WEBHOOK_CALLBACK_URL=            # Publiczny URL callbacku, np. https://api.example.com/api/scout/webhook
SCOUT_WEBHOOK_SECRET=                  # HMAC-SHA256 sekret do weryfikacji podpisów hubów

# Transkrypcja audio/wideo (faster-whisper lokalnie)
SCOUT_WHISPER_MODEL=base               # tiny|base|small|medium|large-v3 (domyślnie base ~74 MB CPU)
