# =============================================================================
# ESG Data Foundry — zmienne środowiskowe
# Skopiuj do .env i wypełnij. Nigdy nie commituj .env do gita.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=CHANGE_ME

DATABASE_URL=postgresql+psycopg2://esg_user:CHANGE_ME@localhost:5432/esg_foundry
ASYNC_DATABASE_URL=postgresql+asyncpg://esg_user:CHANGE_ME@localhost:5432/esg_foundry

# ── OpenAI — wymagany zawsze (judge + embeddings + generacja Q&A) ─────────────
# Generacja: gpt-4o-mini, ~$2 za 1000 par Q&A, limit 10M TPM (bez limitów dobowych)
OPENAI_API_KEY=sk-XXXX

OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ── Generacja Q&A (OpenAI gpt-4o-mini — domyślny, zero konfiguracji) ─────────
GROQ_API_KEY=
VLLM_BASE_URL=https://api.openai.com/v1
VLLM_MODEL=gpt-4o-mini

# ── PDF Parsing ───────────────────────────────────────────────────────────────
# Domyślnie: PyMuPDF lokalnie (darmowy, bez limitu)
# Opcjonalnie LlamaParse dla złożonych tabel ($0.003/str):
# LLAMA_PARSE_API_KEY=llx-XXXX

# ── Pipeline ─────────────────────────────────────────────────────────────────
ADVERSARIAL_RATIO=0.10
QUALITY_THRESHOLD=0.75
MAX_RETRIES_PER_CHUNK=3
MAX_TURNS=3
MAX_REFUSAL_RATIO=0.10
WATERMARK_INTERVAL=50
BATCH_SIZE=10

# ── HuggingFace (trening lokalny — opcjonalny) ───────────────────────────────
HF_TOKEN=hf_XXXX

# ── Ollama (chatbot — opcjonalny) ────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
