# =============================================================================
# ESG Data Foundry — zmienne środowiskowe
# Skopiuj do .env i wypełnij. Nigdy nie commituj .env do gita.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=CHANGE_ME

# ── Database URLs (wymagane przez settings.py) ────────────────────────────────
# W Docker Compose te wartości są budowane automatycznie z POSTGRES_USER/PASSWORD.
# Do lokalnego uruchomienia POZA Dockerem ustaw je ręcznie (zamień CHANGE_ME na POSTGRES_PASSWORD):
DATABASE_URL=postgresql+psycopg2://esg_user:CHANGE_ME_strong_password_here@localhost:5432/esg_foundry
ASYNC_DATABASE_URL=postgresql+asyncpg://esg_user:CHANGE_ME_strong_password_here@localhost:5432/esg_foundry

# ── Groq (Llama 3.3 70B — PRIMARY question/answer generator) ─────────────────
# Get free API key at: https://console.groq.com
# Leave empty to fall back to OpenAI for question generation
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXX
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── OpenAI — wymagany zawsze (judge + embeddings + generacja Q&A) ─────────────
# Generacja: gpt-4o-mini, ~$2 za 1000 par Q&A, limit 10M TPM (bez limitów dobowych)
OPENAI_API_KEY=sk-XXXX

# ── vLLM / Hugging Face (only if running local GPU with sm70+ — optional) ────
# Leave as-is if using Groq + OpenAI (no local GPU needed).
# Gdy używasz lokalnego vLLM (--profile gpu), zmień też VLLM_BASE_URL i VLLM_API_KEY:
#   VLLM_BASE_URL=http://vllm:8000/v1
#   VLLM_API_KEY=not-needed
#   VLLM_MODEL=llama3   ← musi pasować do --served-model-name w docker-compose.yml
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXX
VLLM_MODEL=gpt-4o-mini

# ── OpenAI (judge + embeddings — zawsze wymagany) ─────────────────────────────
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ── Generacja Q&A (OpenAI gpt-4o-mini — domyślny, zero konfiguracji) ─────────
GROQ_API_KEY=
VLLM_BASE_URL=https://api.openai.com/v1
VLLM_MODEL=gpt-4o-mini

# ── PDF Parsing ───────────────────────────────────────────────────────────────
# Domyślnie: PyMuPDF lokalnie (darmowy, bez limitu)
# Opcjonalnie LlamaParse dla złożonych tabel ($0.003/str):
# LLAMA_PARSE_API_KEY=llx-XXXX

# ── Pipeline ─────────────────────────────────────────────────────────────────
ADVERSARIAL_RATIO=0.10
QUALITY_THRESHOLD=0.75
MAX_RETRIES_PER_CHUNK=3
MAX_TURNS=3
MAX_REFUSAL_RATIO=0.10
WATERMARK_INTERVAL=50
BATCH_SIZE=10

# ── HuggingFace (trening lokalny — opcjonalny) ───────────────────────────────
HF_TOKEN=hf_XXXX

# ── Ollama (chatbot — opcjonalny) ────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434

# ── PRO features ─────────────────────────────────────────────────────────────
DEDUP_THRESHOLD=0.85          # MinHash Jaccard threshold for near-duplicate removal (0.0–1.0)
CROSS_DOC_SAMPLES=50          # cross-document synthesis Q&A pairs per run (0 = disabled)
DPO_OUTPUT_FILE=/app/output/dataset_esg_v1_dpo.jsonl   # DPO preference pairs output
VLLM_MAX_TOKENS=1536          # max tokens for Groq/vLLM generation (increase for longer CoT)

# ── Batch / Output ───────────────────────────────────────────────────────────
BATCH_ID=esg-production-v1    # logical run identifier
OUTPUT_FILE=/app/output/dataset_esg_v1.jsonl
CLIENT_ID=client_acme_2024    # unique per customer for B2B watermark tracking

# ── Tenacity backoff (OpenAI/Groq rate-limit retry) ─────────────────────────
TENACITY_MAX_ATTEMPTS=6
TENACITY_INITIAL_WAIT=2.0     # seconds (doubles each retry: 2→4→8→16→32→64)
TENACITY_MAX_WAIT=64.0

# ── Rate-limit throttling ─────────────────────────────────────────────────────
# Seconds to sleep between chunks (prevents Groq/OpenAI 429 rate-limit storms).
# Groq free tier: 12k TPM — at 2s delay fits ~30 chunks/min comfortably.
# Increase to 5+ if you still see many 429s. Set to 0 for paid tiers.
CHUNK_DELAY_SECONDS=2.0

# ── B2B Watermark secret ─────────────────────────────────────────────────────
# Change to a long random string — used in watermark hash derivation
FOUNDRY_WATERMARK_SECRET=change-me-to-a-random-256-bit-secret

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
