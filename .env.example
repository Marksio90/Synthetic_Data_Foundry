# =============================================================================
# ESG Data Foundry — zmienne środowiskowe
# Skopiuj do .env i wypełnij. Nigdy nie commituj .env do gita.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=esg_user
POSTGRES_PASSWORD=CHANGE_ME

# Database URLs — w Docker Compose budowane automatycznie z POSTGRES_USER/PASSWORD.
# Przy uruchomieniu POZA Dockerem ustaw ręcznie (zamień CHANGE_ME na swoje hasło):
DATABASE_URL=postgresql+psycopg2://esg_user:CHANGE_ME@localhost:5432/esg_foundry
ASYNC_DATABASE_URL=postgresql+asyncpg://esg_user:CHANGE_ME@localhost:5432/esg_foundry

# ── OpenAI — wymagany do oceny jakości (Judge) i embeddingów ─────────────────
# Judge: gpt-4o-mini (~$0.15/1M tokenów)
# Embeddingi: text-embedding-3-small — można zastąpić Ollama (USE_LOCAL_EMBEDDINGS=true)
OPENAI_API_KEY=sk-XXXX

OPENAI_PRIMARY_MODEL=gpt-4o-mini   # judge — szybki, tani ($0.15/1M tokenów)
OPENAI_FALLBACK_MODEL=gpt-4o       # tylko gdy mini niepewny (~5% przypadków, $2.5/1M)

# ── LOCAL MODEL (Ollama) — PODSTAWOWY, DARMOWY ────────────────────────────────
# Generacja Q&A przez model lokalny. Wymagania: ~5 GB RAM (phi4-mini).
# 32 GB RAM = wystarczy z DUŻĄ rezerwą.
#
# Modele pobierane AUTOMATYCZNIE przez Docker przy starcie (docker compose up).
# Jeśli model już istnieje → NIE pobiera ponownie (idempotentne).
# Ręczna zmiana modelu: zmień OLLAMA_MODEL poniżej i zrestartuj docker compose.
#
OLLAMA_MODEL=phi4-mini
OLLAMA_EMBED_MODEL=nomic-embed-text
USE_LOCAL_EMBEDDINGS=false          # zmień na true aby używać lokalnych embeddingów (Ollama)
OLLAMA_URL=http://ollama:11434      # adres Ollama w Docker (nie zmieniaj)

# ── SECONDARY provider — Cerebras [REKOMENDOWANY — 1M tokenów/dzień FREE] ────
#
# Cerebras to chip wafer-scale — najszybszy darmowy inference na rynku.
# 2000+ tokenów/sek, 1M tokenów/dzień gratis, model identyczny z Ollama lokalnym.
# Klucz: https://cloud.cerebras.ai → Sign up → API Keys → Create
#
SECONDARY_API_KEY=csk-XXXX
SECONDARY_BASE_URL=https://api.cerebras.ai/v1
SECONDARY_MODEL=llama3.1-8b
#   Wyższa jakość (też FREE): SECONDARY_MODEL=llama3.3-70b
#
# ─── Alternatywy (odkomentuj i zastąp powyższe 3 linie) ──────────────────────
#
# OpenRouter (darmowe LLaMA, ~20 req/min):
#   SECONDARY_API_KEY=sk-or-XXXX
#   SECONDARY_BASE_URL=https://openrouter.ai/api/v1
#   SECONDARY_MODEL=meta-llama/llama-3.1-8b-instruct:free
#
# Together AI ($0.18/1M tokenów — najtańszy płatny, bez limitów):
#   SECONDARY_API_KEY=XXXX
#   SECONDARY_BASE_URL=https://api.together.xyz/v1
#   SECONDARY_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# ── OpenAI/vLLM — FALLBACK 3/3 (gdy Ollama i secondary niedostępne) ─────────
VLLM_BASE_URL=https://api.openai.com/v1
VLLM_MODEL=gpt-4o-mini

# ── PDF Parsing — PyMuPDF lokalnie (darmowy, bez limitu) ─────────────────────
# Opcjonalnie LlamaParse dla złożonych tabel PDF ($0.003/str):
# LLAMA_PARSE_API_KEY=llx-XXXX

# ── Pipeline ──────────────────────────────────────────────────────────────────
ADVERSARIAL_RATIO=0.10
QUALITY_THRESHOLD=0.75
MAX_RETRIES_PER_CHUNK=3
MAX_TURNS=3
MAX_REFUSAL_RATIO=0.10
WATERMARK_INTERVAL=50
BATCH_SIZE=10
CHUNK_DELAY_SECONDS=0          # opóźnienie między chunkami w sek. (0 = brak dla OpenAI)

# ── PRO features ──────────────────────────────────────────────────────────────
DEDUP_THRESHOLD=0.85           # próg Jaccard dla MinHash (usuwa prawie-duplikaty)
CROSS_DOC_SAMPLES=50           # pary Q&A między dokumentami (0 = wyłączone)
VLLM_MAX_TOKENS=2048           # maks. tokenów na odpowiedź (zwiększone dla bogatszego CoT)

# ── Batch / Output ────────────────────────────────────────────────────────────
BATCH_ID=esg-production-v1
OUTPUT_FILE=/app/output/dataset_esg_v1.jsonl
DPO_OUTPUT_FILE=/app/output/dataset_esg_v1_dpo.jsonl
CLIENT_ID=client_acme_2024     # unikalny per klient (B2B watermark)

# ── Tenacity — backoff przy błędach API ───────────────────────────────────────
TENACITY_MAX_ATTEMPTS=6
TENACITY_INITIAL_WAIT=2.0      # sekundy (podwaja się: 2→4→8→16→32→64)
TENACITY_MAX_WAIT=64.0

# ── HuggingFace (trening lokalny — opcjonalny) ────────────────────────────────
HF_TOKEN=hf_XXXX

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
